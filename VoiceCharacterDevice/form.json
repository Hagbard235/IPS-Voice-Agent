{
  "elements":
  [
    {
      "type": "ValidationTextBox",
      "name": "Name",
      "caption": "Character Name"
    },
    {
      "type": "ValidationTextBox",
      "name": "Voice_ID",
      "caption": "ElevenLabs Voice ID"
    },
    {
      "type": "Select",
      "name": "Model_ID",
      "caption": "ElevenLabs Model",
      "options": [
        { "caption": "Multilingual v2 (empfohlen)", "value": "eleven_multilingual_v2" },
        { "caption": "Turbo v2.5 (schneller)", "value": "eleven_turbo_v2_5" },
        { "caption": "Turbo v2 (schnell)", "value": "eleven_turbo_v2" },
        { "caption": "Monolingual v1 (nur Englisch)", "value": "eleven_monolingual_v1" }
      ]
    },
    {
      "type": "ValidationTextBox",
      "name": "LLM_SystemPrompt",
      "caption": "LLM System Prompt (Director's Note)",
      "multiline": true,
      "width": "100%"
    },
    {
      "type": "SelectMedia",
      "name": "Character_Image",
      "caption": "Character Image (Optional)"
    },
    {
      "type": "NumberSpinner",
      "name": "Max_Variations",
      "caption": "Max Variations per Event",
      "minimum": 1
    }
  ],
  "actions":
  [
    {
      "type": "ExpansionPanel",
      "caption": "🧪 Test: Speak + Echo Announce",
      "items": [
        {
          "type": "ValidationTextBox",
          "name": "TestSpeak_Event",
          "caption": "Event Name",
          "value": "test_greeting"
        },
        {
          "type": "ValidationTextBox",
          "name": "TestSpeak_Text",
          "caption": "Text",
          "value": "Es ist Zeit aufzustehen!"
        },
        {
          "type": "ValidationTextBox",
          "name": "TestSpeak_Echos",
          "caption": "Echo Devices (JSON Array, leer = kein Echo)",
          "value": ""
        },
        {
          "type": "Button",
          "caption": "🚀 Speak + Upload + Echo Test",
          "onClick": "echo IVD_TestSpeakAndAnnounce($id, $TestSpeak_Event, $TestSpeak_Text, $TestSpeak_Echos);"
        },
        {
          "type": "Button",
          "caption": "🔇 Nur Speak (ohne Echo)",
          "onClick": "echo IVD_TestSpeak($id, $TestSpeak_Event, $TestSpeak_Text);"
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "🧪 Test: DataFlow zum Gateway",
      "items": [
        {
          "type": "ValidationTextBox",
          "name": "TestDF_Text",
          "caption": "Test-Text",
          "value": "Hallo Welt!"
        },
        {
          "type": "Button",
          "caption": "🚀 DataFlow Test (nur LLM)",
          "onClick": "echo IVD_TestDataFlow($id, $TestDF_Text);"
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "ℹ️ Diagnose",
      "items": [
        {
          "type": "Button",
          "caption": "📊 Status prüfen",
          "onClick": "echo IVD_GetDiagnostics($id);"
        }
      ]
    }
  ],
  "status":
  [
    { "code": 102, "icon": "active", "caption": "Charakter aktiv" },
    { "code": 200, "icon": "error", "caption": "Konfiguration unvollständig" },
    { "code": 201, "icon": "error", "caption": "Kein Gateway verbunden" }
  ]
}
